{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chummer.run/contracts/release-authority-v2.schema.json",
  "title": "Chummer release authority v2 and publication contracts",
  "description": "Portable contract for approved scope, CURRENT.json, SNAPSHOT.json, accepted generated release-decision files, and the exact Registry publication request. Registry remains the derivation owner and persists generated manifest/decision bytes unchanged.",
  "oneOf": [
    { "$ref": "#/$defs/approvedScopeDecision" },
    { "$ref": "#/$defs/current" },
    { "$ref": "#/$defs/snapshot" },
    { "$ref": "#/$defs/previewDecision" },
    { "$ref": "#/$defs/stableDecision" },
    { "$ref": "#/$defs/publishRequest" }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "releaseVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._+-]+$",
      "not": { "enum": [".", ".."] }
    },
    "normalizedToken": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._+-]*$"
    },
    "normalizedIdentifier": {
      "type": "string",
      "pattern": "^(?!unknown$|missing$|invalid$)[a-z0-9][a-z0-9._+-]*$"
    },
    "decisionStatus": {
      "enum": [
        "review_required",
        "preview_ready",
        "stable_ready"
      ]
    },
    "installAccessClass": {
      "enum": [
        "open_public",
        "account_recommended",
        "account_required"
      ]
    },
    "downloadAccessPosture": {
      "enum": [
        "unavailable",
        "open_public",
        "account_recommended",
        "account_required",
        "mixed"
      ]
    },
    "current": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "releaseVersion",
        "snapshotSha256",
        "decisionSha256",
        "status"
      ],
      "properties": {
        "releaseVersion": { "$ref": "#/$defs/releaseVersion" },
        "snapshotSha256": { "$ref": "#/$defs/sha256" },
        "decisionSha256": { "$ref": "#/$defs/sha256" },
        "status": { "$ref": "#/$defs/decisionStatus" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "head",
        "platform",
        "rid",
        "arch",
        "kind",
        "downloadUrl",
        "sha256",
        "sizeBytes",
        "compatibilityState",
        "promotionState",
        "publicationScope",
        "revokeState",
        "publicInstallRoute",
        "installAccessClass"
      ],
      "properties": {
        "artifactId": { "$ref": "#/$defs/normalizedIdentifier" },
        "head": { "$ref": "#/$defs/normalizedIdentifier" },
        "platform": { "$ref": "#/$defs/normalizedIdentifier" },
        "rid": { "$ref": "#/$defs/normalizedIdentifier" },
        "arch": { "$ref": "#/$defs/normalizedIdentifier" },
        "kind": { "const": "installer" },
        "downloadUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "^/downloads/g/(?!\\.{1,2}(?:/|$))(?!(?:[^/]*%(?:2[eEfF]|5[cC])))[^/?#\\\\\\s]+/(?:files|install)/(?!\\.{1,2}$)(?!(?:[^/]*%(?:2[eEfF]|5[cC])))[^/?#\\\\\\s]+$"
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "compatibilityState": { "const": "compatible" },
        "promotionState": { "const": "promoted" },
        "publicationScope": { "const": "signed-in-and-public" },
        "revokeState": { "const": "not_revoked" },
        "publicInstallRoute": {
          "type": "string",
          "pattern": "^/downloads/(?:install/|g/(?!\\.{1,2}(?:/|$))[^/?#\\\\]+/install/)(?!\\.{1,2}$)(?!.*%(?:2[eEfF]|5[cC]))[^/?#\\\\\\x00-\\x1f\\x7f]+$"
        },
        "installAccessClass": { "$ref": "#/$defs/installAccessClass" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "installAccessClass": { "const": "open_public" } },
            "required": ["installAccessClass"]
          },
          "then": {
            "properties": {
              "downloadUrl": {
                "pattern": "^/downloads/g/[^/?#\\\\]+/files/[^/?#\\\\]+$"
              }
            }
          },
          "else": {
            "properties": {
              "downloadUrl": {
                "pattern": "^/downloads/g/[^/?#\\\\]+/install/[^/?#\\\\]+$"
              },
              "publicInstallRoute": {
                "pattern": "^/downloads/g/[^/?#\\\\]+/install/[^/?#\\\\]+$"
              }
            }
          }
        }
      ]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorityContract",
        "releaseVersion",
        "channel",
        "status",
        "rolloutState",
        "supportabilityState",
        "availablePlatforms",
        "primaryHeadByPlatform",
        "artifactCount",
        "downloadAccessPosture",
        "knownIssueSummary",
        "manifestSha256",
        "registryRepository",
        "registryCommit",
        "releaseDecisionStatus",
        "releaseDecisionSha256",
        "releaseDecisionPath",
        "supportOwner",
        "nextActions",
        "artifacts",
        "manifestPath"
      ],
      "properties": {
        "authorityContract": { "const": "chummer.release-authority-snapshot/v2" },
        "releaseVersion": { "$ref": "#/$defs/releaseVersion" },
        "channel": { "$ref": "#/$defs/normalizedToken" },
        "status": { "$ref": "#/$defs/normalizedToken" },
        "rolloutState": { "$ref": "#/$defs/normalizedToken" },
        "supportabilityState": { "$ref": "#/$defs/normalizedToken" },
        "availablePlatforms": {
          "type": "array",
          "items": { "$ref": "#/$defs/normalizedIdentifier" },
          "uniqueItems": true
        },
        "primaryHeadByPlatform": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/normalizedIdentifier" },
          "additionalProperties": { "$ref": "#/$defs/normalizedIdentifier" }
        },
        "artifactCount": { "type": "integer", "minimum": 0 },
        "downloadAccessPosture": { "$ref": "#/$defs/downloadAccessPosture" },
        "knownIssueSummary": { "type": "string", "minLength": 1 },
        "manifestSha256": { "$ref": "#/$defs/sha256" },
        "registryRepository": { "const": "ArchonMegalon/chummer6-hub-registry" },
        "registryCommit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "releaseDecisionStatus": { "$ref": "#/$defs/decisionStatus" },
        "releaseDecisionSha256": { "$ref": "#/$defs/sha256" },
        "releaseDecisionPath": { "const": "RELEASE_DECISION.json" },
        "supportOwner": { "type": "string", "minLength": 1 },
        "nextActions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" }
        },
        "manifestPath": { "const": "RELEASE_CHANNEL.json" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifacts": { "maxItems": 0 }
            }
          },
          "then": {
            "properties": {
              "artifactCount": { "const": 0 },
              "availablePlatforms": { "maxItems": 0 },
              "primaryHeadByPlatform": { "maxProperties": 0 },
              "downloadAccessPosture": { "const": "unavailable" },
              "releaseDecisionStatus": { "const": "review_required" }
            }
          },
          "else": {
            "properties": {
              "artifactCount": { "minimum": 1 },
              "availablePlatforms": { "minItems": 1 },
              "primaryHeadByPlatform": { "minProperties": 1 },
              "downloadAccessPosture": {
                "enum": [
                  "open_public",
                  "account_recommended",
                  "account_required",
                  "mixed"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "releaseDecisionStatus": { "const": "review_required" }
            }
          },
          "then": {
            "properties": {
              "nextActions": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "releaseDecisionStatus": {
                "enum": ["preview_ready", "stable_ready"]
              }
            }
          },
          "then": {
            "properties": {
              "artifacts": { "minItems": 1 },
              "availablePlatforms": { "minItems": 1 },
              "primaryHeadByPlatform": { "minProperties": 1 }
            }
          }
        }
      ],
      "x-chummer-derivation-invariants": {
        "artifactCount": "Must equal artifacts.length.",
        "artifacts": "Must equal the ordinal artifactId-sorted canonical projection re-derived from the exact manifest bytes. Each source artifact has kind=installer and compatibilityState=compatible; exactly one matching desktopRouteTruth row has promotionState=promoted, routeRole primary or fallback, updateEligibility=eligible, installPosture=installer_first, revokeState=not_revoked, and a publicInstallRoute; exactly one matching artifactPublicationBindings row has publicationScope=signed-in-and-public, publicationState=published, a publicShelfRef, and the same tuple/route/channel/version. Channel and artifact active-revocation facts must be clear.",
        "availablePlatforms": "Must equal the sorted distinct platform values from eligible artifacts.",
        "primaryHeadByPlatform": "Must be derived only from eligible desktopRouteTruth rows with routeRole=primary, exactly one per eligible platform; never inferred from artifact presence or order.",
        "downloadAccessPosture": "Must be unavailable for an empty shelf, the single recognized installAccessClass when all eligible artifacts share one, or mixed when multiple recognized classes occur.",
        "immutableArtifact": "open_public downloadUrl must be the exact root-relative Hub generation file projection /downloads/g/{generationId}/files/{fileName} and remain distinct from publicInstallRoute. account_recommended/account_required downloadUrl must equal the protected /downloads/g/{generationId}/install/{artifactId} route. All routes reject query, fragment, credentials, and traversal; sha256 and positive sizeBytes are pinned from the same exact manifest row."
      }
    },
    "approvedScopePlatform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactAccessClass",
        "fallbackHeads",
        "platform",
        "primaryHead",
        "rid",
        "signingRequirement"
      ],
      "properties": {
        "artifactAccessClass": {
          "enum": ["open_public", "account_required", "support_directed"]
        },
        "fallbackHeads": {
          "type": "array",
          "maxItems": 15,
          "uniqueItems": true,
          "items": { "enum": ["avalonia", "blazor-desktop"] }
        },
        "platform": { "enum": ["linux", "macos", "windows"] },
        "primaryHead": { "enum": ["avalonia", "blazor-desktop"] },
        "rid": {
          "enum": [
            "linux-x64", "linux-arm64", "osx-x64", "osx-arm64",
            "win-x64", "win-arm64"
          ]
        },
        "signingRequirement": {
          "enum": ["signed", "preview_unsigned_allowed", "not_applicable"]
        }
      }
    },
    "approvedScopeDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approvedAtUtc",
        "approvedBy",
        "channel",
        "contractName",
        "contractVersion",
        "decisionId",
        "platforms",
        "releaseTarget",
        "releaseVersion",
        "status",
        "supportOwner"
      ],
      "properties": {
        "approvedAtUtc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "approvedBy": { "type": "string", "minLength": 1, "maxLength": 256 },
        "channel": { "const": "preview" },
        "contractName": { "const": "chummer.release-scope-decision/v1" },
        "contractVersion": { "const": 1 },
        "decisionId": { "$ref": "#/$defs/normalizedIdentifier" },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/approvedScopePlatform" }
        },
        "releaseTarget": { "const": "preview" },
        "releaseVersion": { "$ref": "#/$defs/normalizedIdentifier" },
        "status": { "const": "approved" },
        "supportOwner": { "$ref": "#/$defs/normalizedIdentifier" }
      },
      "x-chummer-canonical-bytes-invariant": "Exact compact recursively-key-sorted UTF-8 JSON plus LF; rows and fallbackHeads are unique ordinally sorted and platform/RID compatible."
    },
    "publicationMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "releaseVersion", "channel", "status", "rolloutState",
        "supportabilityState", "availablePlatforms", "primaryHeadByPlatform",
        "artifactCount", "downloadAccessPosture", "knownIssueSummary",
        "registryRepository", "registryCommit", "supportOwner", "nextActions",
        "artifacts"
      ],
      "properties": {
        "releaseVersion": { "$ref": "#/$defs/releaseVersion" },
        "channel": { "$ref": "#/$defs/normalizedIdentifier" },
        "status": { "$ref": "#/$defs/normalizedIdentifier" },
        "rolloutState": { "$ref": "#/$defs/normalizedIdentifier" },
        "supportabilityState": { "$ref": "#/$defs/normalizedIdentifier" },
        "availablePlatforms": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/normalizedIdentifier" }
        },
        "primaryHeadByPlatform": {
          "type": "object",
          "maxProperties": 16,
          "propertyNames": { "$ref": "#/$defs/normalizedIdentifier" },
          "additionalProperties": { "$ref": "#/$defs/normalizedIdentifier" }
        },
        "artifactCount": { "type": "integer", "minimum": 0, "maximum": 256 },
        "downloadAccessPosture": { "$ref": "#/$defs/downloadAccessPosture" },
        "knownIssueSummary": { "type": "string", "minLength": 1, "maxLength": 512 },
        "registryRepository": { "const": "ArchonMegalon/chummer6-hub-registry" },
        "registryCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "supportOwner": { "type": "string", "minLength": 1, "maxLength": 256 },
        "nextActions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "artifacts": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/artifact" }
        }
      }
    },
    "canonicalBase64": {
      "type": "string",
      "minLength": 4,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    },
    "publishRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "manifestBytes",
        "releaseScopeDecisionBytes",
        "expectedReleaseScopeDecisionSha256",
        "releaseDecisionBytes",
        "expectedCurrentSnapshotSha256"
      ],
      "properties": {
        "metadata": { "$ref": "#/$defs/publicationMetadata" },
        "manifestBytes": { "$ref": "#/$defs/canonicalBase64" },
        "releaseScopeDecisionBytes": { "$ref": "#/$defs/canonicalBase64" },
        "expectedReleaseScopeDecisionSha256": { "$ref": "#/$defs/sha256" },
        "releaseDecisionBytes": { "$ref": "#/$defs/canonicalBase64" },
        "expectedCurrentSnapshotSha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      },
      "x-chummer-scope-binding-invariant": "Registry validates the exact approved-scope bytes against expectedReleaseScopeDecisionSha256 and derives releaseVersion, availablePlatforms, primaryHeadByPlatform, and supportOwner from that scope."
    },
    "previewFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "summary"],
      "properties": {
        "id": { "type": "string", "pattern": "^preview_[1-9][0-9]*$" },
        "severity": { "const": "release_truth" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "previewDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractName",
        "generatedAt",
        "status",
        "releaseDecisionStatus",
        "verdict",
        "releaseVersion",
        "releaseScopeDecisionSha256",
        "channel",
        "platforms",
        "primaryHeadByPlatform",
        "fallbackHeadsByPlatform",
        "artifactAccessClass",
        "supportOwner",
        "nextActions",
        "registryCommit",
        "manifestSha256",
        "authoritySnapshotSha256",
        "candidateDecisionStatus",
        "candidateDecisionSha256",
        "manifestGeneratedAt",
        "scorecardSha256",
        "convergenceSha256",
        "blockingFindings"
      ],
      "properties": {
        "contractName": { "const": "chummer.preview-release-decision/v1" },
        "generatedAt": { "type": "string", "minLength": 1, "maxLength": 128 },
        "status": { "enum": ["review_required", "preview_ready"] },
        "releaseDecisionStatus": { "enum": ["review_required", "preview_ready"] },
        "verdict": {
          "enum": ["PREVIEW_RELEASE_REVIEW_REQUIRED", "PREVIEW_READY"]
        },
        "releaseVersion": { "$ref": "#/$defs/releaseVersion" },
        "releaseScopeDecisionSha256": { "$ref": "#/$defs/sha256" },
        "channel": { "$ref": "#/$defs/normalizedToken" },
        "platforms": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/normalizedIdentifier" },
          "uniqueItems": true
        },
        "primaryHeadByPlatform": {
          "type": "object",
          "maxProperties": 16,
          "propertyNames": { "$ref": "#/$defs/normalizedIdentifier" },
          "additionalProperties": { "$ref": "#/$defs/normalizedIdentifier" }
        },
        "fallbackHeadsByPlatform": {
          "type": "object",
          "maxProperties": 16,
          "propertyNames": { "$ref": "#/$defs/normalizedIdentifier" },
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/normalizedIdentifier" },
            "uniqueItems": true
          }
        },
        "artifactAccessClass": {
          "enum": [
            "review_required",
            "open_public",
            "account_recommended",
            "account_required",
            "mixed"
          ]
        },
        "supportOwner": { "type": "string", "minLength": 1, "maxLength": 256 },
        "nextActions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "registryCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "manifestSha256": { "$ref": "#/$defs/sha256" },
        "authoritySnapshotSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "candidateDecisionStatus": {
          "enum": ["", "review_required", "preview_ready"]
        },
        "candidateDecisionSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "manifestGeneratedAt": { "type": "string", "minLength": 1, "maxLength": 128 },
        "scorecardSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "convergenceSha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "blockingFindings": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/previewFinding" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "releaseDecisionStatus": { "const": "review_required" }
            },
            "required": ["releaseDecisionStatus"]
          },
          "then": {
            "properties": {
              "status": { "const": "review_required" },
              "verdict": { "const": "PREVIEW_RELEASE_REVIEW_REQUIRED" },
              "blockingFindings": { "minItems": 1 }
            }
          },
          "else": {
            "properties": {
              "status": { "const": "preview_ready" },
              "verdict": { "const": "PREVIEW_READY" },
              "authoritySnapshotSha256": { "$ref": "#/$defs/sha256" },
              "candidateDecisionStatus": {
                "enum": ["review_required", "preview_ready"]
              },
              "candidateDecisionSha256": { "$ref": "#/$defs/sha256" },
              "scorecardSha256": { "$ref": "#/$defs/sha256" },
              "convergenceSha256": { "$ref": "#/$defs/sha256" },
              "blockingFindings": { "maxItems": 0 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authoritySnapshotSha256": { "const": "" }
            },
            "required": ["authoritySnapshotSha256"]
          },
          "then": {
            "properties": {
              "candidateDecisionStatus": { "const": "" },
              "candidateDecisionSha256": { "const": "" }
            }
          },
          "else": {
            "properties": {
              "candidateDecisionStatus": {
                "enum": ["review_required", "preview_ready"]
              },
              "candidateDecisionSha256": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      ],
      "x-chummer-candidate-seed-invariant": "review_required may seed from exact manifest bytes with the candidate triple and proof digests empty. preview_ready requires exact predecessor CURRENT/SNAPSHOT/RELEASE_DECISION bytes plus passing scorecard and generation-bound convergence proof bytes.",
      "x-chummer-scope-binding-invariant": "channel, registryCommit, platforms, primaryHeadByPlatform, canonical manifest-derived fallbackHeadsByPlatform, supportOwner, nextActions, artifactAccessClass, manifest timestamp, and proof digests must exactly bind SNAPSHOT.json and immutable proof bytes."
    },
    "stableDecision": {
      "type": "object",
      "required": [
        "contract_name",
        "contract_version",
        "releaseVersion",
        "releaseDecisionStatus",
        "status",
        "live_release",
        "release_authority"
      ],
      "properties": {
        "contract_name": { "const": "chummer.final_gold_graph" },
        "contract_version": { "const": 2 },
        "releaseVersion": { "$ref": "#/$defs/releaseVersion" },
        "releaseDecisionStatus": { "const": "stable_ready" },
        "status": { "const": "pass" },
        "live_release": {
          "type": "object",
          "required": [
            "version",
            "channel",
            "manifest_sha256",
            "registry_commit",
            "available_platforms",
            "primary_head_by_platform",
            "status",
            "rollout_state",
            "supportability_state",
            "artifact_count",
            "download_access_posture",
            "known_issue_summary",
            "release_decision_status"
          ],
          "properties": {
            "version": { "$ref": "#/$defs/releaseVersion" },
            "channel": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]*$" },
            "manifest_sha256": { "$ref": "#/$defs/sha256" },
            "registry_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
            "available_platforms": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^(?!unknown$|missing$|invalid$)[a-z0-9][a-z0-9._+-]*$"
              }
            },
            "primary_head_by_platform": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^(?!unknown$|missing$|invalid$)[a-z0-9][a-z0-9._+-]*$"
              },
              "additionalProperties": {
                "type": "string",
                "pattern": "^(?!unknown$|missing$|invalid$)[a-z0-9][a-z0-9._+-]*$"
              }
            },
            "status": { "type": "string", "minLength": 1 },
            "rollout_state": { "type": "string", "minLength": 1 },
            "supportability_state": { "type": "string", "minLength": 1 },
            "artifact_count": { "type": "integer", "minimum": 1 },
            "download_access_posture": {
              "enum": ["open_public", "account_recommended", "account_required", "mixed"]
            },
            "known_issue_summary": { "type": "string", "minLength": 1 },
            "release_decision_status": { "const": "stable_ready" }
          },
          "additionalProperties": true
        },
        "release_authority": {
          "type": "object",
          "required": [
            "contract",
            "manifest_sha256",
            "registry_commit",
            "release_decision_status"
          ],
